# ── Credenciais — Arista cEOS ─────────────────────────────────────────────────
USER_DEVICE=admin
PASSW_DEVICE=admin

# ── Credenciais — Nokia SR Linux ──────────────────────────────────────────────
# SR Linux usa senha diferente por padrão. O username pode ser o mesmo.
PASSW_DEVICE_NOKIA=NokiaSrl1!

# ── IPs de gerência (conforme containerlab) ───────────────────────────────────
DEVICE_01=192.168.100.101   # Arista router-01
DEVICE_03=192.168.100.103   # Nokia srl-01

# ── Servidor Temporal ─────────────────────────────────────────────────────────
TEMPORAL_ADDRESS=localhost:7233

# ── Telegram Bot (exercícios com notificações) ────────────────────────────────
BOT_TOKEN=your_bot_token_here
CHAT_ID=your_chat_id_here
